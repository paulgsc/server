# ─────────────────────────────────────────────────────────────
# Core Paths (REQUIRED)
# Must exist at startup (container-mounted, read-only)
# ─────────────────────────────────────────────────────────────
PIPELINE_PROMPTS_DIR=/app/prompts

# Dump mode output (only used if LLM_MODE=dump)
PROMPTS_OUT_DIR=/app/pipeline-prompts


# ─────────────────────────────────────────────────────────────
# LLM Configuration
# ─────────────────────────────────────────────────────────────
# Modes:
#   local → Ollama / OpenAI-compatible endpoint
#   dump  → writes prompts to disk for manual completion
LLM_MODE=local

# Model used by LocalLlm (Ollama/OpenAI-compatible)
LLM_MODEL=llama3

# Ollama base host (no /v1 suffix; code appends it)
OLLAMA_HOST=http://localhost:11434

# Optional: only required if using OpenAI-compatible APIs
OPENAI_API_KEY=


# ─────────────────────────────────────────────────────────────
# Embedding Configuration
# ─────────────────────────────────────────────────────────────
# Options: ollama | openai
EMBED_PROVIDER=ollama

# Used only when EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small


# ─────────────────────────────────────────────────────────────
# Pipeline Heuristics
# ─────────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.65
WINDOW_SIZE=20


# ─────────────────────────────────────────────────────────────
# Infrastructure (IO contract)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
NATS_URL=nats://127.0.0.1:4222


# ─────────────────────────────────────────────────────────────
# Worker Runtime
# ─────────────────────────────────────────────────────────────
# Each worker = 1 in-flight JetStream message
PIPELINE_WORKERS=2

# Must exceed worst-case full pipeline latency
PIPELINE_ACK_WAIT_SECS=600

# Max redelivery attempts before TERM → DLQ
PIPELINE_MAX_DELIVER=5


# ─────────────────────────────────────────────────────────────
# JetStream / Transport Limits
# ─────────────────────────────────────────────────────────────
# Stream-level max bytes (guardrail)
NATS_MAX_STREAM_BYTES=536870912   # 512MB

# Per-message max size (guardrail)
NATS_MAX_MSG_BYTES=8388608        # 8MB


# ─────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────
# Examples:
#   info
#   debug
#   tabsched_pipeline=debug,info
RUST_LOG=info
